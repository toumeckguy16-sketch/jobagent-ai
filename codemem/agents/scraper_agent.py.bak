"""
Agent Scraper (F2)
Collecte automatiquement les offres d'emploi via l'API Tavily Search.

Pourquoi Tavily ?
- API de recherche web conçue pour les agents IA
- Aucun blocage anti-scraping à gérer
- Retourne des résultats structurés directement
- Nativement intégré à LangChain
- Plan gratuit : 1000 requêtes/mois (https://tavily.com)
"""

import os
import re
from typing import List, Dict, Any, Optional

from langchain_community.tools.tavily_search import TavilySearchResults


class ScraperAgent:
    """
    Agent responsable de la collecte des offres d'emploi.
    Utilise l'API Tavily pour rechercher les offres sur le web
    sans avoir à gérer les blocages anti-scraping.

    Flux :
        profile_text
            │
            ▼
        _build_queries()  
            │
            ▼ →  construit des requêtes ciblées
        TavilySearchResults  
            │
            ▼
        _parse_results() →  normalise en format interne
            │            →  recherche sur cameroundesk, minajob, etc.
            ▼
        _deduplicate()  
            │
            ▼ →  supprime les doublons
        List[dict] (JobSearchState)
    """

    # Sites ciblés dans les requêtes Tavily
    TARGET_SITES = ["cameroundesk.com", "minajob.com", "emploi.cm"]

    # ============================================================
    # INITIALISATION
    # ============================================================
    def __init__(self, max_results: int = 5):
        """
        Args:
            max_results: Nombre de résultats max par requête Tavily
        """
        self.max_results = max_results
        self.tavily = TavilySearchResults(
            max_results=max_results,
            api_key=os.getenv("TAVILY_API_KEY"),
            include_raw_content=True,
        )

    # ============================================================
    # MÉTHODE PRINCIPALE
    # ============================================================
    def scrape(self, query: str, max_jobs: int = 5) -> List[Dict[str, Any]]:
        """
        Recherche des offres d'emploi correspondant au profil.

        Args:
            query:    Texte du profil candidat (issu du CVParser)
            max_jobs: Nombre maximum d'offres à retourner

        Returns:
            Liste de dicts {title, company, location, description, url, source}
        """
        print("  → [ScraperAgent] Recherche via Tavily...")
        
        keywords = self._extract_keywords(query)
        queries = self._build_queries(keywords)
        all_jobs = []

        for q in queries:
            try:
                print(f"     Requête : {q}")
                results = self.tavily.invoke(q)
                jobs = self._parse_results(results)
                all_jobs.extend(jobs)
            except Exception as e:
                print(f"  ⚠ Erreur Tavily pour '{q}': {e}")

        unique_jobs = self._deduplicate(all_jobs)
        
        # -- Assurer la diversité des sources (Exigence: Au moins 3) --
        from collections import defaultdict
        source_map = defaultdict(list)
        for job in unique_jobs:
            source_map[job["source"]].append(job)
            
        diverse_jobs = []
        while source_map and len(diverse_jobs) < max_jobs:
            for src in list(source_map.keys()):
                if len(diverse_jobs) >= max_jobs:
                    break
                diverse_jobs.append(source_map[src].pop(0))
                if not source_map[src]:
                    del source_map[src]

        print(f"  ✅ {len(diverse_jobs)} offres collectées avec diversité")
        return diverse_jobs

    # ============================================================
    # CONSTRUCTION DES REQUÊTES
    # ============================================================
    def _build_queries(self, keywords: List[str]) -> List[str]:
        """
        Construit plusieurs requêtes de recherche ciblées
        pour maximiser la couverture des résultats.

        Exemple pour ["data", "scientist", "python"] :
          - "offre emploi data scientist python site:cameroundesk.com"
          - "offre emploi data scientist python site:minajob.com"
          - "offre emploi data scientist python Cameroun 2026"
        """
        base = " ".join(keywords[:4])
        queries = []

        for site in self.TARGET_SITES:
            # On inclut obligatoirement "2025" dans la recherche
            queries.append(f"offre emploi 2026 {base} site:{site}")

        queries.append(f"offre emploi 2026 {base} Cameroun")
        
        return queries

    # ============================================================
    # PARSING DES RÉSULTATS TAVILY
    # ============================================================
    def _parse_results(self, results: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        """
        Normalise les résultats bruts de Tavily au format interne.

        Format Tavily → Format interne :
        { url, title, content, score }  →  { title, company, location, description, url, source }
        """
        jobs = []

        for r in results:
            url = r.get("url", "")
            title = r.get("title", "Offre d'emploi")
            content = r.get("content", "") or r.get("raw_content", "")
            
            # --- Exigence : Ignorer les annonces expirées ---
            if "annonce expirée" in title.lower() or "annonce expirée" in content.lower():
                continue
            
            source = self._identify_source(url)
            company = self._extract_company(content, title)
            location = self._extract_location(content)
            expiration_date = self._extract_expiration_date(content)
            description = content[:600].strip() if content else title

            jobs.append({
                "title": self._clean_title(title),
                "company": company,
                "location": location,
                "expiration_date": expiration_date,
                "description": description,
                "url": url,
                "source": source,
            })

        return jobs

    # ============================================================
    # UTILITAIRES D'EXTRACTION
    # ============================================================
    def _extract_keywords(self, profile: str) -> List[str]:
        """Extrait les mots-clés pertinents du profil"""
        stopwords = {
            "je", "suis", "un", "une", "le", "la", "les", "et", "de",
            "du", "des", "en", "au", "avec", "pour", "dans", "sur",
            "mon", "ma", "mes", "par", "que", "qui", "plus", "ans"
        }
        
        words = profile.lower().split()
        keywords = [w.strip(".,;:!?") for w in words if len(w) > 3 and w not in stopwords]
        
        # Déduplication
        seen, unique = set(), []
        for k in keywords:
            if k not in seen:
                seen.add(k)
                unique.append(k)
                
        return unique[:6]

    def _identify_source(self, url: str) -> str:
        """Identifie le site source depuis l'URL"""
        url_lower = url.lower()
        
        if "cameroundesk" in url_lower:
            return "cameroundesk"
        if "minajob" in url_lower:
            return "minajob"
        if "emploi.cm" in url_lower:
            return "emploi.cm"
            
        try:
            return url.split("//")[1].split("/")[0].replace("www.", "")
        except Exception:
            return "web"

    def _extract_company(self, content: str, title: str) -> str:
        """Tente d'extraire le nom de l'entreprise depuis le contenu"""
        patterns = [
            r"(?:entreprise|société|company|employeur)\s*[:\-]\s*([A-Z][^\n,]{2,40})",
            r"(?:recrutement|recrute)\s+(?:pour|chez)\s+([A-Z][^\n,]{2,40})",
            r"([A-Z][A-Z\s]{2,30})\s+(?:recrute|recherche)",
        ]
        
        for pattern in patterns:
            match = re.search(pattern, content, re.IGNORECASE)
            if match:
                return match.group(1).strip()
                
        return "N/A"

    def _extract_location(self, content: str) -> str:
        """Extrait la localisation depuis le contenu"""
        cities = [
            "Yaoundé", "Douala", "Bafoussam", "Garoua", "Maroua",
            "Bamenda", "Ngaoundéré", "Bertoua", "Kumba", "Limbe"
        ]
        
        for city in cities:
            if city.lower() in content.lower():
                return city
                
        if "cameroun" in content.lower():
            return "Cameroun"
            
        return "N/A"

    def _extract_expiration_date(self, content: str) -> str:
        """Tente d'extraire la date d'expiration de l'offre depuis le contenu"""
        patterns = [
            r"(?:date limite|expire le|clôture|jusqu'au|deadline)\s*[:\-]?\s*([0-9]{1,2}(?:\s*[a-zA-Zéû]{3,9}\s*|\/|\-)[0-9]{2,4})"
        ]
        
        for pattern in patterns:
            match = re.search(pattern, content, re.IGNORECASE)
            if match:
                return match.group(1).strip()
                
        return "N/A"

    def _clean_title(self, title: str) -> str:
        """Nettoie le titre de la page web pour n'en garder que le poste"""
        title = re.sub(
            r"\s*[\|\-–]\s*(cameroundesk|minajob|emploi\.cm).*$",
            "",
            title,
            flags=re.IGNORECASE
        )
        title = re.sub(
            r"\s*[\|\-–]\s*offres?\s+d.emploi.*$",
            "",
            title,
            flags=re.IGNORECASE
        )
        
        return title.strip()

    # ============================================================
    # DÉDUPLICATION
    # ============================================================
    def _deduplicate(self, jobs: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        """Supprime les doublons basés sur l'URL et le titre"""
        seen_urls = set()
        seen_titles = set()
        unique = []

        for job in jobs:
            url_key = job.get("url", "").lower()
            title_key = job.get("title", "").lower()[:50]
            
            if url_key not in seen_urls and title_key not in seen_titles:
                seen_urls.add(url_key)
                seen_titles.add(title_key)
                unique.append(job)

        return unique

    # ============================================================
    # MODE MOCK (sans clé API)
    # ============================================================
    @staticmethod
    def mock_scrape(query: str) -> List[Dict[str, Any]]:
        """
        Données fictives pour tester sans clé Tavily.
        
        Args:
            query: Texte du profil (non utilisé en mode mock)
            
        Returns:
            Liste d'offres d'emploi fictives
        """
        return [
            {
                "title": "Data Scientist",
                "company": "Orange Cameroun",
                "location": "Douala",
                "description": (
                    "Nous recherchons un Data Scientist passionné. "
                    "Compétences requises : Python, Machine Learning, SQL, "
                    "TensorFlow, Power BI. Expérience 2 ans minimum."
                ),
                "url": "https://www.cameroundesk.com/emploi/data-scientist-orange",
                "source": "cameroundesk"
            },
            {
                "title": "Ingénieur Data / BI",
                "company": "MTN Cameroun",
                "location": "Yaoundé",
                "description": (
                    "Poste d'ingénieur BI pour rejoindre notre équipe data. "
                    "Maîtrise de Power BI, SQL Server, Python et Azure requise. "
                    "Bonne connaissance des ETL."
                ),
                "url": "https://www.minajob.com/offres/ingenieur-bi-mtn",
                "source": "minajob"
            },
            {
                "title": "Analyste Data",
                "company": "Afriland First Bank",
                "location": "Yaoundé",
                "description": (
                    "Nous cherchons un analyste data pour notre département risk. "
                    "Profil : Python, R, statistiques, visualisation de données. "
                    "Master en Data Science ou équivalent exigé."
                ),
                "url": "https://www.cameroundesk.com/emploi/analyste-data-afriland",
                "source": "cameroundesk"
            },
        ]